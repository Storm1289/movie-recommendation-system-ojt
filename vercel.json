{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/*.py": {
      "maxDuration": 60,
      "includeFiles": "backend/**",
      "excludeFiles": "{backend/**/*.pkl,backend/**/__pycache__/**,backend/**/test_*.py,backend/test_dir.py,backend/seed.py,backend/scripts/**,backend/requirements-model.txt,frontend/**,movie prd.pdf,Readme.md}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
